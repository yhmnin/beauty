generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Person {
  id          String   @id @default(cuid())
  name        String
  nationality String
  birthYear   Int
  deathYear   Int?
  bio         String   @db.Text
  imageUrl    String
  categories  String[]
  notableWorks String[]
  embedding   Unsupported("vector(512)")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  works       Work[]

  @@map("people")
}

model Work {
  id          String   @id @default(cuid())
  title       String
  year        String
  description String   @db.Text
  category    String
  imageUrl    String
  tags        String[]
  movement    String?
  embedding   Unsupported("vector(512)")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     Person?  @relation(fields: [creatorId], references: [id])
  creatorId   String?

  @@map("works")
}

model Movement {
  id              String   @id @default(cuid())
  name            String   @unique
  period          String
  description     String   @db.Text
  keyFigures      String[]
  characteristics String[]
  imageUrl        String
  embedding       Unsupported("vector(512)")?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("movements")
}

model AestheticEvent {
  id           String   @id @default(cuid())
  name         String
  year         String
  location     String
  description  String   @db.Text
  significance String   @db.Text
  imageUrl     String
  category     String
  embedding    Unsupported("vector(512)")?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("aesthetic_events")
}

model TasteProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  interests Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]

  @@map("taste_profiles")
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   TasteProfile? @relation(fields: [profileId], references: [id])
  profileId String?

  messages  Message[]

  @@map("conversations")
}

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  @@map("messages")
}
